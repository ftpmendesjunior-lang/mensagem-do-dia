o found success as a radio DJ. Yiruma continues to tour and record through Europe and Asia where he is enjoying superstar status."},"callToAction":{"simpleText":"VISITE O CANAL"},"dismiss":{"simpleText":"CANCELAR"},"endpoint":{"clickTrackingParams":"CAcQ-N4BGAAiEwjKjpuax8yTAxVBCB4AHTzCHxwyDGl2LWVuZHNjcmVlbkjt5cDuiKeis-4BygEEZY4tWg==","commandMetadata":{"webCommandMetadata":{"url":"/channel/UCo_JrFWufLEcTvYJZEt1R0w","webPageType":"WEB_PAGE_TYPE_CHANNEL","rootVe":3611,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"UCo_JrFWufLEcTvYJZEt1R0w"}},"hovercardButton":{"subscribeButtonRenderer":{"buttonText":{"runs":[{"text":"INSCREVER-SE"}]},"subscribed":false,"enabled":true,"type":"FREE","channelId":"UCo_JrFWufLEcTvYJZEt1R0w","showPreferences":false,"subscribedButtonText":{"runs":[{"text":"INSCRITO"}]},"unsubscribedButtonText":{"runs":[{"text":"INSCREVER-SE"}]},"trackingParams":"CAgQmysiEwjKjpuax8yTAxVBCB4AHTzCHxwyDGl2LWVuZHNjcmVlbg==","unsubscribeButtonText":{"runs":[{"text":"CANCELAR INSCRIÇÃO"}]},"serviceEndpoints":[{"clickTrackingParams":"CAgQmysiEwjKjpuax8yTAxVBCB4AHTzCHxwyDGl2LWVuZHNjcmVlbsoBBGWOLVo=","commandMetadata":{"webCommandMetadata":{"sendPost":true,"apiUrl":"/youtubei/v1/subscription/subscribe"}},"subscribeEndpoint":{"channelIds":["UCo_JrFWufLEcTvYJZEt1R0w"],"params":"EgIIBBgA"}},{"clickTrackingParams":"CAgQmysiEwjKjpuax8yTAxVBCB4AHTzCHxzKAQRlji1a","commandMetadata":{"webCommandMetadata":{"sendPost":true}},"signalServiceEndpoint":{"signal":"CLIENT_SIGNAL","actions":[{"clickTrackingParams":"CAgQmysiEwjKjpuax8yTAxVBCB4AHTzCHxzKAQRlji1a","openPopupAction":{"popup":{"confirmDialogRenderer":{"trackingParams":"CAkQxjgiEwjKjpuax8yTAxVBCB4AHTzCHxw=","dialogMessages":[{"runs":[{"text":"Cancelar inscrição no canal "},{"text":"YirumaVEVO"},{"text":"?"}]}],"confirmButton":{"buttonRenderer":{"style":"STYLE_BLUE_TEXT","size":"SIZE_DEFAULT","isDisabled":false,"text":{"runs":[{"text":"Cancelar inscrição"}]},"serviceEndpoint":{"clickTrackingParams":"CAsQ8FsiEwj